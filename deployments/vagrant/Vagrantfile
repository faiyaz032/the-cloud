Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  # Load Balancer (The Bridge)
  config.vm.define "lb01" do |lb|
    lb.vm.hostname = "lb01"
    # Public-facing interface
    lb.vm.network "private_network", ip: "192.168.56.10"
    # Internal Backend interface
    lb.vm.network "private_network", ip: "192.168.57.10"
    lb.vm.provider "virtualbox" do |v|
      v.memory = 512
    end
  end

  # Compute nodes (Work in progress for Week 3)
  ["compute01", "compute02"].each_with_index do |name, i|
    config.vm.define name do |node|
      node.vm.hostname = name
      node.vm.network "private_network", ip: "192.168.56.#{11+i}"
      node.vm.provider "virtualbox" do |v|
        v.memory = 1024
      end
    end
  end

  # Storage nodes (Internal Network Only)
  ["storage01", "storage02"].each_with_index do |name, i|
    config.vm.define name do |node|
      node.vm.hostname = name
      node.vm.network "private_network", ip: "192.168.57.#{11+i}"
      node.vm.provider "virtualbox" do |v|
        v.memory = 512
      end
    end
  end

  config.vm.synced_folder "../../", "/home/vagrant/cloud"
end